{
  "name": "beer-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "eslint . && next dev",
    "dev:skip-lint": "next dev",
    "dev:docker": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:unused": "knip",
    "lint:unused-exports": "knip --exports",
    "typecheck": "tsc --noEmit",
    "sync-worker": "tsx scripts/sync-worker.ts",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile cron up --build",
    "check:i18n": "tsx scripts/i18n/check-messages-parity.ts",
    "i18n:export": "tsx scripts/i18n/export-messages.ts",
    "i18n:import": "tsx scripts/i18n/import-messages.ts",
    "open-core:export": "tsx scripts/open-core/build-community-core-export.ts",
    "open-core:publish": "bash scripts/open-core/publish-community-core.sh",
    "community:pr": "bash scripts/sync-public-private/contribute-to-community.sh",
    "test": "vitest run && pnpm check:i18n",
    "test:watch": "vitest",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/query-sync-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "axios": "^1.13.2",
    "bullmq": "^5.73.0",
    "ioredis": "^5.10.1",
    "lodash-es": "^4.17.22",
    "lottie-react": "^2.4.1",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "next": "16.0.8",
    "nodemailer": "^8.0.5",
    "nuqs": "^2.8.8",
    "pg": "^8.16.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-snowfall": "^2.4.0",
    "react-xarrows": "^2.0.2",
    "recharts": "^2.12.7",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.0.10",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/nextjs-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9",
    "eslint-plugin-perfectionist": "^5.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^5.76.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.31",
    "storybook": "^10.3.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.5",
    "vitest": "3.2.4"
  },
  "license": "UNLICENSED"
}
